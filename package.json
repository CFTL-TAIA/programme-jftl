{
  "name": "projet-api-taia",
  "version": "0.1.0",
  "private": true,
  "description": "API de test TAIA avec front statique et API serverless compatible Vercel",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "admin-token": "node ./scripts/print-admin-token.mjs",
