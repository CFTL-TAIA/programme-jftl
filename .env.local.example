# Variables locales admin TAIA
# Copier ce fichier vers .env.local puis remplacer les valeurs.
# Pour developper avec le meme comportement qu'en production, definir taia_bdd_DATABASE_URL
# vers votre Postgres local ou votre base Neon.
# Pour tester les uploads sans toucher la production, definir aussi
# taia_READ_WRITE_TOKEN vers un store Blob de developpement dedie.
# Ne jamais recopier de vraies valeurs dans README.md, docs/chat.md ou toute autre doc versionnee.

TAIA_ADMIN_EDITOR_PASSWORD=change-me-editor
TAIA_ADMIN_SUPER_PASSWORD=change-me-admin-plus
taia_bdd_DATABASE_URL=postgresql://taia:taia@localhost:5432/taia
taia_READ_WRITE_TOKEN=vercel_blob_rw_change-me