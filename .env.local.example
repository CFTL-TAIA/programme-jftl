# Variables locales admin TAIA
# Copier ce fichier vers .env.local puis remplacer les valeurs.
# Pour forcer le localhost a utiliser uniquement BDD/ et les medias locaux,
# definir TAIA_STORAGE_MODE=local meme si les tokens Blob sont presents.

TAIA_ADMIN_EDITOR_PASSWORD=change-me-editor
TAIA_ADMIN_SUPER_PASSWORD=change-me-admin-plus
TAIA_STORAGE_MODE=local