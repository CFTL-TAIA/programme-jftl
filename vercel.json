{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/admin/token",
      "destination": "/api/admin-token"
    },
    {
      "source": "/api/admin/media",
      "destination": "/api/admin-media"
    }
  ]
}